# SRI Environment Variables
# Copy this file to .env and fill in your keys
# Never commit your actual .env file

# LLM Provider (choose one)
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# Zep Cloud (for Hermes persistent memory)
ZEP_API_KEY=your_zep_key_here
ZEP_API_URL=https://api.getzep.com

# MiroFish
MIROFISH_API_KEY=your_mirofish_key_here

# SRI Settings
SRI_DEFAULT_MODEL=claude-sonnet-4-20250514
SRI_MAX_COMPLEXITY_BUDGET=8
SRI_HUMAN_GATE_ENABLED=true
SRI_LOG_LEVEL=INFO
